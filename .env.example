# Neo uses ~/.neo/neo.db by default. Uncomment to override the database path.
# NEO_DATABASE_URL=sqlite+aiosqlite:///neo.db
NEO_DB_SQL_DEBUG=false
NEO_EMBEDDING_PROVIDER=openai
NEO_EMBEDDING_API_KEY=
NEO_EMBEDDING_MODEL=text-embedding-3-small
NEO_EMBEDDING_DIMENSIONS=1536
NEO_EMBEDDING_FALLBACK_ENABLED=true
NEO_LLM_SPARK_MODEL=claude-haiku-4-5
NEO_LLM_SPARK_API_KEY=
NEO_LLM_CONSOLIDATION_MODEL=claude-sonnet-4-20250514
NEO_LLM_CONSOLIDATION_API_KEY=
NEO_CONSOLIDATION_SCHEDULE=0 */6 * * *
NEO_CONSOLIDATION_NODE_THRESHOLD=20
NEO_CONSOLIDATION_ENABLED=true
NEO_SCHEDULER_POLL_INTERVAL_SECONDS=1.0
NEO_AGENT_NAME=default
NEO_LOG_LEVEL=INFO
NEO_REST_HOST=127.0.0.1
NEO_REST_PORT=8420
